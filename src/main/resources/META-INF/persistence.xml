<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="maPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <!-- <class>fr.epsib3_2526.Livre</class> -->
        <!--<class>fr.epsib3_2526.Client</class>-->
        <!--<class>fr.epsib3_2526.Emprunt</class>-->
        <class>banque.Adresse</class>
        <class>banque.BanqueClass</class>
        <class>banque.Client</class>
        <class>banque.Compte</class>
        <class>banque.Operation</class>
        <class>banque.Virement</class>
        <class>banque.LivretA</class>
        <class>banque.AssuranceVie</class>
        <class>banque.OperationStandard</class>



        <properties>
            <!--Accès à la base de donnée -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver" />
           <!-- <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/bibliotheque?allowPublicKeyRetrieval=true&amp;useSSL=false" /> -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/banque?allowPublicKeyRetrieval=true&amp;useSSL=false" />
            <property name="jakarta.persistence.jdbc.user" value="${env.DB_USER}" />
            <property name="jakarta.persistence.jdbc.password" value="${env.DB_PASS}" />

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect" />
            <!-- Activation de la génération des tables manquantes uniquement -->
            <property name="hibernate.hbm2ddl.auto" value="create"/>

            <!-- Drop and create à chaque redémarrage -->
            <!--Affichage des requêtes SQL -->
            <property name="hibernate.show_sql" value="true" />
            <property name="hibernate.format_sql" value="true" />

            <property name="jakarta.persistence.schema-generation.database.action" value="update" />
        </properties>
    </persistence-unit>
</persistence>